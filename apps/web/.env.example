# =============================================
# OrbitMind Platform — Environment Variables
# =============================================
# NOTA: Credenciais de IA (Claude, OpenAI, Gemini) sao configuradas
# pelo usuario na UI em Settings > Provedores de IA.
# NAO adicione API keys aqui.

# Database
DATABASE_URL=postgresql://orbitmind:orbitmind_dev@localhost:5432/orbitmind

# Auth (NextAuth v5)
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-uma-chave-segura
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth — para login com GitHub (opcional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Nango (integracoes — https://nango.dev)
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=

# WebSocket (use dev:ws para habilitar)
PORT=3000
