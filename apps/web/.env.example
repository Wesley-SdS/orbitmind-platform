# =============================================
# OrbitMind Platform — Environment Variables
# =============================================

# Database
DATABASE_URL=postgresql://orbitmind:orbitmind_dev@localhost:5434/orbitmind

# Auth (NextAuth v5)
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-uma-chave-segura
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth — para login com GitHub (opcional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Gateway (Vercel) — chave unica que roteia para Anthropic/OpenAI/Gemini.
# Obtenha em: https://vercel.com/dashboard/ai-gateway
# Obrigatoria — sem essa chave nenhuma chamada LLM funciona.
AI_GATEWAY_API_KEY=

# Nango (integracoes — https://nango.dev)
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=

# WebSocket (use dev:ws para habilitar)
PORT=3000
